NODE_ENV=development
PORT=8000

STELLAR_NETWORK=testnet

TESTNET_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADX3W
MAINNET_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADX3W

CACHE_TTL_SECONDS=60
HORIZON_TIMEOUT=30000

# Required for on-chain score sync (BK-7). This key signs set_score, so its
# PUBLIC key must be registered as an authorized oracle in the oracle_registry
# (Admin page → Authorize oracle). Keep the secret here only — never in the
# frontend or a commit. When unset, on-chain sync degrades to a no-op.
ADMIN_SECRET_KEY=

# X402 paid-endpoint configuration (BK-8..BK-11).
# Set either PAYMENT_RECEIVE_ADDRESS explicitly, or the public key of
# ADMIN_SECRET_KEY will be used.
PAYMENT_RECEIVE_ADDRESS=
PAYMENT_AMOUNT_XLM=0.5
PAYMENT_REQUEST_TTL_SECONDS=900

# Optional LLM augmentation (BK-AI-1 / BK-AI-2). When set, /score responses
# include aiInsight + aiSuggestions rewritten by Claude. When unset, responses
# fall back to the deterministic rule-based insight/suggestion.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: override the directory used by history.service.ts (defaults to
# <cwd>/data). Useful in containerized deploys with a mounted volume.
FLUXID_DATA_DIR=
